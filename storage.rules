rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Feed post images. Any signed-in member can view; only the uploading
    // member can write into their own folder. Files for deleted posts are
    // removed by the cleanupPostImages Cloud Function (admin SDK).
    match /post-images/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        request.auth.uid == userId &&
        request.resource.size < 10 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*');
      allow update: if false;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Project files uploaded from device. Same owner-folder model as
    // post images (Storage rules can't check Firestore project
    // membership); orphan cleanup runs in the cleanupProjectFiles
    // Cloud Function when a file doc is deleted.
    match /project-files/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        request.auth.uid == userId &&
        request.resource.size < 15 * 1024 * 1024;
      allow update: if false;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Chat photos sent in direct messages. Readable by any signed-in
    // member (conversation docs gate the message list itself); messages
    // are immutable so there is no delete path to clean up.
    match /chat-images/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        request.auth.uid == userId &&
        request.resource.size < 10 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*');
      allow update, delete: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
