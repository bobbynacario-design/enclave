rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Feed post images. Any signed-in member can view; only the uploading
    // member can write into their own folder. Files for deleted posts are
    // removed by the cleanupPostImages Cloud Function (admin SDK).
    match /post-images/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        request.auth.uid == userId &&
        request.resource.size < 10 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*');
      allow update: if false;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
