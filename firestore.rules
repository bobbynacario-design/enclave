rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDocExists() {
      return signedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function ownerAdmin() {
      return signedIn() &&
        request.auth.token.email == 'bobbynacario@gmail.com';
    }

    function isAdmin() {
      return ownerAdmin() ||
        (userDocExists() && userData().isAdmin == true);
    }

    function canAccessCircle(circle) {
      return circle == 'all' ||
        isAdmin() ||
        (
          userDocExists() &&
          userData().circles is list &&
          circle in userData().circles
        );
    }

    function eventExists(eventId) {
      return exists(/databases/$(database)/documents/events/$(eventId));
    }

    function canAccessEvent(eventId) {
      return eventExists(eventId) &&
        canAccessCircle(
          get(/databases/$(database)/documents/events/$(eventId)).data.circle
        );
    }

    function conversationExists(conversationId) {
      return exists(/databases/$(database)/documents/conversations/$(conversationId));
    }

    function canAccessConversation(conversationId) {
      return conversationExists(conversationId) &&
        request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.members;
    }

    function isProjectMember(data) {
      return signedIn() &&
        request.auth.uid in data.memberIds;
    }

    function canAccessProjectData(data) {
      return isAdmin() || (
        data.memberIds is list &&
        isProjectMember(data)
      );
    }

    function canAccessProject(projectId) {
      return exists(/databases/$(database)/documents/projects/$(projectId)) &&
        canAccessProjectData(
          get(/databases/$(database)/documents/projects/$(projectId)).data
        );
    }

    function isProjectOwner(projectId) {
      return signedIn() &&
        exists(/databases/$(database)/documents/projects/$(projectId)) &&
        get(/databases/$(database)/documents/projects/$(projectId)).data.createdBy == request.auth.uid;
    }

    match /allowlist/{email} {
      // Users can only read their own allowlist entry (used during sign-in
      // to determine circle access). Admins can list the full allowlist.
      allow get: if signedIn() &&
        request.auth.token.email.lower() == email;
      allow list: if isAdmin();
      allow create, update: if isAdmin() &&
        request.resource.data.email == email &&
        request.resource.data.circles is list;
      allow delete: if isAdmin();
    }

    match /mail/{mailId} {
      allow create: if isAdmin() &&
        request.resource.data.to is list &&
        request.resource.data.message is map;
      allow get, list: if isAdmin();
      allow update, delete: if false;
    }

    match /users/{userId} {
      allow get: if signedIn();
      // list is broader than ideal: any signed-in user with a user doc can
      // enumerate all members. Accepted because (a) Enclave is an invite-only
      // private community where members already know each other exists, and
      // (b) the Members page and Messages people sidebar both need this query.
      // Email is not displayed in the UI; it's used only for admin invite flows.
      // Reconsider if app moves toward broader access.
      allow list: if userDocExists();

      allow create: if signedIn() &&
        request.auth.uid == userId &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.email == request.auth.token.email &&
        request.resource.data.circles is list &&
        (
          !request.resource.data.keys().hasAny(['isAdmin']) ||
          (ownerAdmin() && request.resource.data.isAdmin is bool)
        );

      allow update: if
        // Admin updates: any field EXCEPT isAdmin can change
        (isAdmin() &&
          request.resource.data.uid == resource.data.uid &&
          request.resource.data.email == resource.data.email &&
          request.resource.data.get('isAdmin', false) == resource.data.get('isAdmin', false)
        ) || (
        // Self-updates: cannot change uid, email, circles, or isAdmin
        signedIn() &&
          request.auth.uid == userId &&
          request.resource.data.uid == resource.data.uid &&
          request.resource.data.email == resource.data.email &&
          request.resource.data.circles == resource.data.circles &&
          request.resource.data.get('isAdmin', false) == resource.data.get('isAdmin', false)
        ) || (
        // Role-change updates: ONLY admins can change isAdmin, and the
        // diff must affect ONLY isAdmin
        isAdmin() &&
          request.resource.data.uid == resource.data.uid &&
          request.resource.data.email == resource.data.email &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isAdmin']) &&
          request.resource.data.isAdmin is bool
        );

      allow delete: if isAdmin();
    }

    match /posts/{postId} {
      allow get, list: if signedIn() &&
        canAccessCircle(resource.data.circle);

      allow create: if (
        isAdmin() &&
        signedIn() &&
        request.resource.data.authorId == request.auth.uid &&
        canAccessCircle(request.resource.data.circle)
      ) || (
        signedIn() &&
        request.resource.data.authorId == request.auth.uid &&
        canAccessCircle(request.resource.data.circle) &&
        (
          !request.resource.data.keys().hasAny(['isPinned']) ||
          request.resource.data.isPinned == false
        )
      );

      allow update: if isAdmin() || (
        signedIn() &&
        resource.data.authorId == request.auth.uid &&
        request.resource.data.authorId == resource.data.authorId &&
        request.resource.data.isPinned == resource.data.isPinned &&
        canAccessCircle(resource.data.circle) &&
        canAccessCircle(request.resource.data.circle)
      ) || (
        signedIn() &&
        canAccessCircle(resource.data.circle) &&
        canAccessCircle(request.resource.data.circle) &&
        request.resource.data.authorId == resource.data.authorId &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reacts']) &&
        request.resource.data.reacts is list
      ) || (
        signedIn() &&
        canAccessCircle(resource.data.circle) &&
        canAccessCircle(request.resource.data.circle) &&
        request.resource.data.authorId == resource.data.authorId &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['comments']) &&
        request.resource.data.comments is list
      );

      allow delete: if isAdmin() || (
        signedIn() &&
        resource.data.authorId == request.auth.uid &&
        canAccessCircle(resource.data.circle)
      );
    }

    match /conversations/{conversationId} {
      allow get: if signedIn() && (
        resource == null ||
        request.auth.uid in resource.data.members
      );
      allow list: if signedIn() &&
        request.auth.uid in resource.data.members;

      allow create: if signedIn() &&
        request.resource.data.members is list &&
        request.resource.data.members.size() == 2 &&
        request.auth.uid in request.resource.data.members;

      allow update: if signedIn() &&
        request.auth.uid in resource.data.members &&
        request.resource.data.members == resource.data.members;

      allow delete: if false;

      match /messages/{messageId} {
        allow get, list: if signedIn() &&
          canAccessConversation(conversationId);

        allow create: if signedIn() &&
          canAccessConversation(conversationId) &&
          request.resource.data.authorId == request.auth.uid &&
          request.resource.data.body is string &&
          request.resource.data.body.size() <= 2000;

        allow update, delete: if false;
      }
    }

    match /projects/{projectId} {
      allow get, list: if isAdmin() || isProjectMember(resource.data) || (
        signedIn() &&
        resource.data.pendingInvites is list &&
        request.auth.token.email in resource.data.pendingInvites
      );

      allow create: if signedIn() &&
        request.resource.data.createdBy == request.auth.uid &&
        request.resource.data.memberIds is list &&
        request.auth.uid in request.resource.data.memberIds &&
        request.resource.data.name is string &&
        request.resource.data.status in ['active', 'on-hold', 'completed'];

      allow update: if isAdmin() || (
        signedIn() &&
        resource.data.createdBy == request.auth.uid &&
        request.resource.data.createdBy == resource.data.createdBy
      ) || (
        // claimPendingInvites self-claim: invited user adds ONLY themselves
        // as a member and removes ONLY their own email from pendingInvites.
        signedIn() &&
        resource.data.pendingInvites is list &&
        request.auth.token.email in resource.data.pendingInvites &&
        request.resource.data.diff(resource.data)
          .affectedKeys().hasOnly(['memberIds', 'memberNames', 'pendingInvites', 'updatedAt']) &&
        // Must add self to memberIds (and only self)
        request.auth.uid in request.resource.data.memberIds &&
        !(request.auth.uid in resource.data.memberIds) &&
        request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1 &&
        // Must remove self from pendingInvites (and only self)
        !(request.auth.token.email in request.resource.data.pendingInvites) &&
        request.resource.data.pendingInvites.size() == resource.data.pendingInvites.size() - 1
      ) || (
        signedIn() &&
        isProjectMember(resource.data) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['taskTotal', 'taskDone', 'updatedAt']) &&
        request.resource.data.taskTotal is int &&
        request.resource.data.taskDone is int
      );

      allow delete: if isAdmin() || (
        signedIn() &&
        resource.data.createdBy == request.auth.uid
      );

      match /comments/{commentId} {
        allow get, list: if canAccessProject(projectId);

        allow create: if canAccessProject(projectId) &&
          request.resource.data.keys().hasOnly(['authorId', 'authorName', 'body', 'createdAt']) &&
          request.resource.data.authorId == request.auth.uid &&
          request.resource.data.authorName is string &&
          request.resource.data.body is string &&
          request.resource.data.body.size() > 0 &&
          request.resource.data.body.size() <= 500;

        allow update: if false;
        allow delete: if isAdmin() || isProjectOwner(projectId);
      }

      match /files/{fileId} {
        allow get, list: if canAccessProject(projectId);

        allow create: if canAccessProject(projectId) &&
          request.resource.data.keys().hasOnly(['fileUrl', 'fileName', 'iconUrl', 'addedBy', 'addedByName', 'addedAt']) &&
          request.resource.data.fileUrl is string &&
          request.resource.data.fileName is string &&
          request.resource.data.iconUrl is string &&
          request.resource.data.addedBy == request.auth.uid &&
          request.resource.data.addedByName is string;

        allow update: if false;
        allow delete: if isAdmin() || isProjectOwner(projectId);
      }

      match /tasks/{taskId} {
        allow get, list: if canAccessProject(projectId);

        allow create: if canAccessProject(projectId) &&
          request.resource.data.keys().hasOnly(['title', 'assigneeId', 'assigneeName', 'dueDate', 'status', 'createdBy', 'createdByName', 'createdAt']) &&
          request.resource.data.title is string &&
          request.resource.data.title.size() > 0 &&
          request.resource.data.title.size() <= 200 &&
          request.resource.data.assigneeId is string &&
          request.resource.data.assigneeName is string &&
          request.resource.data.dueDate is string &&
          request.resource.data.status == 'todo' &&
          request.resource.data.createdBy == request.auth.uid &&
          request.resource.data.createdByName is string;

        allow update: if (
          canAccessProject(projectId) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
          request.resource.data.status in ['todo', 'doing', 'done'] &&
          request.resource.data.title == resource.data.title &&
          request.resource.data.assigneeId == resource.data.assigneeId &&
          request.resource.data.assigneeName == resource.data.assigneeName &&
          request.resource.data.dueDate == resource.data.dueDate &&
          request.resource.data.createdBy == resource.data.createdBy &&
          request.resource.data.createdByName == resource.data.createdByName &&
          request.resource.data.createdAt == resource.data.createdAt
        ) || (
          (isAdmin() || (
            canAccessProject(projectId) &&
            resource.data.createdBy == request.auth.uid
          )) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'title', 'assigneeId', 'assigneeName', 'dueDate']) &&
          request.resource.data.status in ['todo', 'doing', 'done'] &&
          request.resource.data.title is string &&
          request.resource.data.title.size() > 0 &&
          request.resource.data.title.size() <= 200 &&
          request.resource.data.assigneeId is string &&
          request.resource.data.assigneeName is string &&
          request.resource.data.dueDate is string &&
          request.resource.data.createdBy == resource.data.createdBy &&
          request.resource.data.createdByName == resource.data.createdByName &&
          request.resource.data.createdAt == resource.data.createdAt
        );

        allow delete: if isAdmin() || isProjectOwner(projectId) || (
          canAccessProject(projectId) &&
          resource.data.createdBy == request.auth.uid
        );
      }

      match /activity/{activityId} {
        allow get, list: if canAccessProject(projectId);

        allow create: if canAccessProject(projectId) &&
          request.resource.data.keys().hasOnly(['action', 'detail', 'authorId', 'authorName', 'createdAt']) &&
          request.resource.data.action is string &&
          request.resource.data.detail is string &&
          request.resource.data.authorId == request.auth.uid &&
          request.resource.data.authorName is string;

        allow update: if false;
        allow delete: if isAdmin() || isProjectOwner(projectId);
      }
    }

    match /briefings/{briefingId} {
      allow read: if userDocExists();
      allow create: if isAdmin();
      allow delete: if isAdmin();
    }

    match /resources/{resourceId} {
      allow get, list: if signedIn();

      allow create: if signedIn() &&
        request.resource.data.title is string &&
        request.resource.data.url is string &&
        request.resource.data.category in ['podcast', 'video', 'legal', 'tool', 'general'] &&
        request.resource.data.addedBy == request.auth.uid;

      allow update: if isAdmin();

      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow get, list: if signedIn() &&
        resource.data.recipientId == request.auth.uid;

      allow create: if signedIn() &&
        request.resource.data.recipientId is string &&
        request.resource.data.type is string &&
        request.resource.data.message is string &&
        request.resource.data.link is map &&
        request.resource.data.read == false &&
        request.resource.data.actorId == request.auth.uid &&
        request.resource.data.actorName is string;

      allow update: if signedIn() &&
        resource.data.recipientId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']) &&
        request.resource.data.read is bool;

      allow delete: if signedIn() &&
        (resource.data.recipientId == request.auth.uid || isAdmin());
    }

    match /events/{eventId} {
      allow get, list: if signedIn() &&
        canAccessCircle(resource.data.circle);
      allow create, delete: if isAdmin();

      allow update: if isAdmin() || (
        signedIn() &&
        canAccessCircle(resource.data.circle) &&
        canAccessCircle(request.resource.data.circle) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rsvpCount']) &&
        request.resource.data.rsvpCount is int &&
        request.resource.data.rsvpCount >= 0
      );

      match /rsvps/{userId} {
        allow get, list: if signedIn() &&
          canAccessEvent(eventId);

        allow create, update, delete: if signedIn() &&
          request.auth.uid == userId &&
          canAccessEvent(eventId);
      }
    }
  }
}
