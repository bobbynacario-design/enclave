rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDocExists() {
      return signedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function ownerAdmin() {
      return signedIn() &&
        request.auth.token.email == 'bobbynacario@gmail.com';
    }

    function isAdmin() {
      return ownerAdmin() ||
        (userDocExists() && userData().role == 'admin');
    }

    function canAccessCircle(circle) {
      return circle == 'all' ||
        isAdmin() ||
        (
          userDocExists() &&
          userData().circles is list &&
          circle in userData().circles
        );
    }

    function eventExists(eventId) {
      return exists(/databases/$(database)/documents/events/$(eventId));
    }

    function canAccessEvent(eventId) {
      return eventExists(eventId) &&
        canAccessCircle(
          get(/databases/$(database)/documents/events/$(eventId)).data.circle
        );
    }

    match /allowlist/{email} {
      allow get: if signedIn();
      allow list: if isAdmin();
      allow create, update: if isAdmin() &&
        request.resource.data.email == email &&
        request.resource.data.circles is list;
      allow delete: if isAdmin();
    }

    match /mail/{mailId} {
      allow create: if isAdmin() &&
        request.resource.data.to is list &&
        request.resource.data.message is map;
      allow get, list, update, delete: if false;
    }

    match /users/{userId} {
      allow get, list: if signedIn();

      allow create: if signedIn() &&
        request.auth.uid == userId &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.email == request.auth.token.email &&
        (
          request.resource.data.role == '' ||
          (ownerAdmin() && request.resource.data.role == 'admin')
        ) &&
        request.resource.data.circles is list;

      allow update: if isAdmin() || (
        signedIn() &&
        request.auth.uid == userId &&
        request.resource.data.uid == resource.data.uid &&
        request.resource.data.email == resource.data.email &&
        request.resource.data.role != 'admin'
      );

      allow delete: if isAdmin();
    }

    match /posts/{postId} {
      allow get, list: if signedIn() &&
        canAccessCircle(resource.data.circle);

      allow create: if signedIn() &&
        request.resource.data.authorId == request.auth.uid &&
        canAccessCircle(request.resource.data.circle);

      allow update, delete: if isAdmin() || (
        signedIn() &&
        resource.data.authorId == request.auth.uid &&
        request.resource.data.authorId == resource.data.authorId &&
        canAccessCircle(resource.data.circle) &&
        canAccessCircle(request.resource.data.circle)
      );
    }

    match /events/{eventId} {
      allow get, list: if signedIn() &&
        canAccessCircle(resource.data.circle);
      allow create, update, delete: if isAdmin();

      match /rsvps/{userId} {
        allow get, list: if signedIn() &&
          canAccessEvent(eventId);

        allow create, update, delete: if signedIn() &&
          request.auth.uid == userId &&
          canAccessEvent(eventId);
      }
    }
  }
}
